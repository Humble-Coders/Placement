rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isThaparEmail() {
      return isAuthenticated()
        && request.auth.token.email.matches('.*@thapar\\.edu$');
    }

    // Reads the caller's role from /users/{uid}.
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isThaparEmail() && callerRole() == 'admin';
    }

    function isStudent() {
      return isThaparEmail() && callerRole() == 'student';
    }

    function isThaparUser() {
      return isAdmin() || isStudent();
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuthenticated()
                  && (request.auth.uid == uid || isAdmin());

      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'student'
                    && request.resource.data.email == request.auth.token.email;

      // Students may only update non-sensitive fields (e.g. lastLogin).
      // Role and email are immutable for students.
      allow update: if isAuthenticated()
                    && (
                      isAdmin()
                      || (
                        request.auth.uid == uid
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['role', 'email'])
                      )
                    );

      allow delete: if isAdmin();
    }

    // ── /students/{docId} ────────────────────────────────────────────────────
    // Keyed by sanitised email. Publicly readable so the student form can
    // auto-fill name/roll/branch when an email is entered.

    match /students/{docId} {
      // Public read so unauthenticated form can autofill by email doc lookup.
      allow read: if true;

      // Only admins write (via Excel upload).
      allow write: if isAdmin();
    }

    // ── /companies/{id} ──────────────────────────────────────────────────────
    // Publicly readable so the student form can populate its dropdowns.

    match /companies/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── /roles/{id} ──────────────────────────────────────────────────────────

    match /roles/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── /branches/{id} ───────────────────────────────────────────────────────

    match /branches/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── /questions/{id} ──────────────────────────────────────────────────────
    // Placement interview experiences — restricted to authenticated Thapar users.

    match /questions/{id} {
      allow read:  if isThaparUser();
      allow write: if isAdmin();
    }

    // ── /config/{docId} ──────────────────────────────────────────────────────
    // Admin-only configuration (LLM provider, model, API key, last-run status).
    // The Cloud Function (Admin SDK) bypasses these rules and can always write.

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // ── /submissionLocks/{lockId} ────────────────────────────────────────────
    // Dedup lock documents used by the student form transaction.
    // lockId format: sanitizedEmail_companyId_roleId
    // Transaction reads the lock first to detect duplicate submissions within
    // 24 hours, then writes the response + updates the lock atomically.
    // Must be publicly readable and writable because the form has no auth.

    match /submissionLocks/{lockId} {
      allow read, write: if true;
    }

    // ── /raw_responses/{id} ──────────────────────────────────────────────────
    // Student form submissions. Anyone may create (public form, no auth required).
    // Only admins may read, update, or delete.

    match /raw_responses/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── /usage/{uid} ─────────────────────────────────────────────────────────
    // Usage summary per student. Students write their own via increment().
    // Admins can read all summary docs (for the Stats panel leaderboard/charts).

    match /usage/{uid} {
      // Student reads own; admin reads all (needed for collection-level query)
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);

      // Students create/update only their OWN summary.
      // uid field in the document must match the authenticated user.
      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid;

      allow update: if isAuthenticated() && request.auth.uid == uid;

      // Admin can also write (e.g. reset/correct data)
      allow write: if isAdmin();

      // ── /usage/{uid}/daily/{date} ─────────────────────────────────────────
      // One doc per calendar day. Students write own; admins read all.

      match /daily/{date} {
        allow read:  if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
        allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
